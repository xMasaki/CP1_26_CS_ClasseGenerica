<Window x:Class="CP1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema Genérico de Cadastro"
        Height="520"
        Width="850"
        Background="#EEF2F7">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <Border Background="#2563EB"
                CornerRadius="10"
                Padding="12"
                Margin="0 0 0 15">

            <TextBlock Text="Sistema Genérico de Cadastro"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Área de Cadastro -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="2"
                CornerRadius="10"
                Padding="15"
                Margin="0 0 0 15">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <StackPanel Margin="10">
                    <TextBlock Text="ID"
                               FontWeight="Bold"
                               Margin="0 0 0 5"/>
                    <TextBox x:Name="EntradaID"
                             Width="100"
                             Height="30"
                             BorderBrush="#2563EB"
                             BorderThickness="2"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <TextBlock Text="Nome / Informação"
                               FontWeight="Bold"
                               Margin="0 0 0 5"/>
                    <TextBox x:Name="EntradaNome"
                             Width="220"
                             Height="30"
                             BorderBrush="#2563EB"
                             BorderThickness="2"/>
                </StackPanel>

            </StackPanel>

        </Border>

        <!-- Botões de Ação -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="2"
                CornerRadius="10"
                Padding="15"
                Margin="0 0 0 15">

            <WrapPanel HorizontalAlignment="Center">

                <Button Content="Adicionar"
                        Width="110"
                        Height="35"
                        Margin="6"
                        Background="#22C55E"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BtnAdicionarClick"/>

                <Button Content="Listar"
                        Width="110"
                        Height="35"
                        Margin="6"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BtnListarClick"/>

                <Button Content="Buscar"
                        Width="110"
                        Height="35"
                        Margin="6"
                        Background="#F59E0B"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BtnBuscarClick"/>

                <Button Content="Remover"
                        Width="110"
                        Height="35"
                        Margin="6"
                        Background="#EF4444"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BtnRemoverClick"/>

                <Button Content="Limpar"
                        Width="110"
                        Height="35"
                        Margin="6"
                        Background="#6B7280"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BtnLimparClick"/>

            </WrapPanel>

        </Border>

        <!-- Área de Busca e Listagem -->
        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="2"
                CornerRadius="10"
                Padding="15">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Busca -->
                <StackPanel Orientation="Horizontal"
                            Margin="0 0 0 10">

                    <TextBlock Text="Buscar por ID:"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Margin="0 0 10 0"/>

                    <TextBox Width="120"
                             Height="28"
                             BorderBrush="#2563EB"
                             BorderThickness="2"
							 x:Name="EntradaBuscaId"/>

                    <Button Content="Buscar"
                            Width="90"
                            Height="28"
                            Margin="10 0 0 0"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
							Click="BtnBuscarTabelaClick"/>

                </StackPanel>

                <!-- Tabela de dados -->
                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowBackground="#F9FAFB"
                          AlternatingRowBackground="#EEF2FF"
                          BorderBrush="#CBD5E1"
                          BorderThickness="1"
                          x:Name="TabelaDados">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
											Binding="{Binding Id}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Informação"
											Binding="{Binding Info}"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</Window>